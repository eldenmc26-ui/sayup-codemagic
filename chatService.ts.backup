// src/services/chatService.ts
import { Firestore, Database, Collections, RTDBPaths, Auth, FirestoreFieldValue } from './firebase';
import type { TalksyUser } from './authService';

export interface Message {
  id:        string;
  senderId:  string;
  content:   string;
  type:      'text' | 'image';
  timestamp: number;
  read:      boolean;
}

export interface Chat {
  id:           string;
  participants: string[];
  lastMessage:  string;
  lastTs:       number;
  unread:       Record<string, number>;
  isGroup?:     boolean;
  groupName?:   string;
}

export async function sendFriendRequest(otherUid: string): Promise<void> {
  const myUid = Auth.currentUser!.uid;
  if (myUid === otherUid) {
    throw new Error('Non puoi aggiungere te stesso');
  }

  const [mySnap, otherSnap] = await Promise.all([
    Firestore.collection(Collections.USERS).doc(myUid).get(),
    Firestore.collection(Collections.USERS).doc(otherUid).get(),
  ]);

  if (!mySnap.exists || !otherSnap.exists) {
    throw new Error('Utente non trovato');
  }

  const myUser = mySnap.data() as TalksyUser;
  if (myUser.friends?.includes(otherUid)) {
    throw new Error('Siete gia amici');
  }
  if (myUser.outgoingFriendRequests?.includes(otherUid)) {
    throw new Error('Richiesta gia inviata');
  }
  if (myUser.incomingFriendRequests?.includes(otherUid)) {
    throw new Error('Hai gia una richiesta da questo utente');
  }

  const batch = Firestore.batch();
  batch.update(Firestore.collection(Collections.USERS).doc(myUid), {
    outgoingFriendRequests: FirestoreFieldValue.arrayUnion(otherUid),
  });
  batch.update(Firestore.collection(Collections.USERS).doc(otherUid), {
    incomingFriendRequests: FirestoreFieldValue.arrayUnion(myUid),
  });
  await batch.commit();

  // Salva notifica per il destinatario
  await Firestore.collection('notifications').add({
    title: 'Nuova richiesta di amicizia',
    body: `${myUser.displayName} (${myUser.nickname}) vuole essere tuo amico!`,
    type: 'friend',
    targetUid: otherUid,
    fromUid: myUid,
    read: false,
    createdAt: Date.now(),
  });
}

export async function acceptFriendRequest(otherUid: string): Promise<void> {
  const myUid = Auth.currentUser!.uid;
  const batch = Firestore.batch();

  batch.update(Firestore.collection(Collections.USERS).doc(myUid), {
    incomingFriendRequests: FirestoreFieldValue.arrayRemove(otherUid),
    friends: FirestoreFieldValue.arrayUnion(otherUid),
  });
  batch.update(Firestore.collection(Collections.USERS).doc(otherUid), {
    outgoingFriendRequests: FirestoreFieldValue.arrayRemove(myUid),
    friends: FirestoreFieldValue.arrayUnion(myUid),
  });

  await batch.commit();

  // Notifica l'altro utente che la richiesta è stata accettata
  const myDoc = await Firestore.collection(Collections.USERS).doc(myUid).get();
  const myData = myDoc.data() as TalksyUser;
  await Firestore.collection('notifications').add({
    title: 'Richiesta accettata!',
    body: `${myData.displayName} ha accettato la tua richiesta di amicizia.`,
    type: 'friend',
    targetUid: otherUid,
    fromUid: myUid,
    read: false,
    createdAt: Date.now(),
  });
}

export async function declineFriendRequest(otherUid: string): Promise<void> {
  const myUid = Auth.currentUser!.uid;
  const batch = Firestore.batch();

  batch.update(Firestore.collection(Collections.USERS).doc(myUid), {
    incomingFriendRequests: FirestoreFieldValue.arrayRemove(otherUid),
  });
  batch.update(Firestore.collection(Collections.USERS).doc(otherUid), {
    outgoingFriendRequests: FirestoreFieldValue.arrayRemove(myUid),
  });

  await batch.commit();
}

export function subscribeFriends(
  callback: (friends: TalksyUser[]) => void,
  onError?: () => void,
): () => void {
  const myUid = Auth.currentUser!.uid;

  return Firestore.collection(Collections.USERS).doc(myUid).onSnapshot(
    async (snap: any) => {
      const data = snap.data() as TalksyUser | undefined;
      const friendIds = data?.friends ?? [];
      if (friendIds.length === 0) {
        callback([]);
        return;
      }

      const docs = await Promise.all(
        friendIds.map((uid) => Firestore.collection(Collections.USERS).doc(uid).get()),
      );
      callback(docs.filter((doc) => doc.exists).map((doc) => doc.data() as TalksyUser));
    },
    () => {
      onError?.();
    },
  );
}

export function subscribeIncomingFriendRequests(
  callback: (users: TalksyUser[]) => void,
  onError?: () => void,
): () => void {
  const myUid = Auth.currentUser!.uid;

  return Firestore.collection(Collections.USERS).doc(myUid).onSnapshot(
    async (snap: any) => {
      const data = snap.data() as TalksyUser | undefined;
      const requestIds = data?.incomingFriendRequests ?? [];
      if (requestIds.length === 0) {
        callback([]);
        return;
      }

      const docs = await Promise.all(
        requestIds.map((uid) => Firestore.collection(Collections.USERS).doc(uid).get()),
      );
      callback(docs.filter((doc) => doc.exists).map((doc) => doc.data() as TalksyUser));
    },
    () => {
      onError?.();
    },
  );
}

export async function ensureChatParticipants(chatId: string): Promise<void> {
  const chatDoc = await Firestore.collection(Collections.CHATS).doc(chatId).get();
  const chat = chatDoc.data() as Chat | undefined;
  if (!chat?.participants?.length) return;

  const participantsObj: Record<string, boolean> = {};
  chat.participants.forEach((uid) => { participantsObj[uid] = true; });

  await Database.ref(`chatParticipants/${chatId}`).set(participantsObj);
}

// Crea o recupera una chat 1:1 tra due utenti
export async function getOrCreateChat(otherUid: string): Promise<string> {
  const myUid = Auth.currentUser!.uid;
  const ids   = [myUid, otherUid].sort();
  const chatId = ids.join('_');

  const chatDoc = await Firestore.collection(Collections.CHATS).doc(chatId).get();
  if (!chatDoc.exists) {
    await Firestore.collection(Collections.CHATS).doc(chatId).set({
      id:           chatId,
      participants: ids,
      lastMessage:  '',
      lastTs:       Date.now(),
      unread:       { [myUid]: 0, [otherUid]: 0 },
    } as Chat);
  }

  await ensureChatParticipants(chatId);
  return chatId;
}

// Invia un messaggio
export async function sendMessage(chatId: string, content: string): Promise<void> {
  await ensureChatParticipants(chatId);
  const myUid = Auth.currentUser!.uid;
  const msgRef = Database.ref(RTDBPaths.messages(chatId)).push();

  const msg: Message = {
    id:        msgRef.key!,
    senderId:  myUid,
    content,
    type:      'text',
    timestamp: Date.now(),
    read:      false,
  };

  await msgRef.set(msg);

  // Aggiorna lastMessage su Firestore
  await Firestore.collection(Collections.CHATS).doc(chatId).update({
    lastMessage: content,
    lastTs:      msg.timestamp,
  });

  // Recupera info chat per inviare notifica agli altri partecipanti
  const chatDoc = await Firestore.collection(Collections.CHATS).doc(chatId).get();
  const chat = chatDoc.data() as Chat | undefined;
  if (!chat) return;

  const myUserDoc = await Firestore.collection(Collections.USERS).doc(myUid).get();
  const myUser = myUserDoc.data() as TalksyUser | undefined;

  const otherParticipants = chat.participants.filter((uid) => uid !== myUid);
  for (const targetUid of otherParticipants) {
    await Firestore.collection('notifications').add({
      title: chat.isGroup ? `Nuovo messaggio in ${chat.groupName}` : `Messaggio da ${myUser?.displayName ?? 'Talksy'}`,
      body: content,
      type: 'message',
      targetUid,
      fromUid: myUid,
      chatId,
      read: false,
      createdAt: Date.now(),
    });
  }
}

// Sottoscrivi ai messaggi in tempo reale
export function subscribeToMessages(
  chatId:   string,
  callback: (messages: Message[]) => void,
): () => void {
  const ref = Database.ref(RTDBPaths.messages(chatId));

  const handler = ref.on('value', (snap: any) => {
    const raw  = snap.val() ?? {};
    const msgs = Object.values(raw) as Message[];
    msgs.sort((a, b) => a.timestamp - b.timestamp);
    callback(msgs);
  });

  return () => ref.off('value', handler);
}

// Sottoscrivi alla lista chat dell'utente
export function subscribeChats(
  callback: (chats: Chat[]) => void,
  onError?: () => void,
): () => void {
  const myUid = Auth.currentUser!.uid;
  const unsub = Firestore
    .collection(Collections.CHATS)
    .where('participants', 'array-contains', myUid)
    .orderBy('lastTs', 'desc')
    .onSnapshot(
      (snap: any) => {
        const chats = snap.docs.map((d: any) => d.data() as Chat);
        callback(chats);
      },
      () => {
        onError?.();
      },
    );
  return unsub;
}

// Imposta il typing indicator
export function setTyping(chatId: string, isTyping: boolean): void {
  const myUid = Auth.currentUser!.uid;
  Database.ref(`${RTDBPaths.typing(chatId)}/${myUid}`).set(isTyping ? true : null);
}

// Aggiorna la presenza online
export function setPresence(online: boolean): void {
  const myUid = Auth.currentUser!.uid;
  const ref   = Database.ref(RTDBPaths.presence(myUid));
  ref.set({ online, lastSeen: Date.now() });
  if (online) ref.onDisconnect().set({ online: false, lastSeen: Date.now() });
}

// Crea una chat di gruppo
export async function createGroupChat(groupName: string, participantUids: string[]): Promise<string> {
  const myUid = Auth.currentUser!.uid;
  const allParticipants = Array.from(new Set([myUid, ...participantUids])).sort();

  const ref = Firestore.collection(Collections.CHATS).doc();
  const unread: Record<string, number> = {};
  allParticipants.forEach((uid) => { unread[uid] = 0; });

  const chat: Chat = {
    id: ref.id,
    participants: allParticipants,
    lastMessage: '',
    lastTs: Date.now(),
    unread,
    isGroup: true,
    groupName: groupName.trim(),
  };

  await ref.set(chat);

  const participantsObj: Record<string, boolean> = {};
  allParticipants.forEach((uid) => { participantsObj[uid] = true; });
  await Database.ref(`chatParticipants/${ref.id}`).set(participantsObj);

  return ref.id;
}

// Cerca utenti per nickname
export async function searchUsers(query: string): Promise<TalksyUser[]> {
  const snap = await Firestore
    .collection(Collections.USERS)
    .where('nickname', '>=', query.toLowerCase())
    .where('nickname', '<=', query.toLowerCase() + '\uf8ff')
    .limit(20)
    .get();
  return snap.docs.map((d: any) => d.data() as TalksyUser);
}
