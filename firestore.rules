// Regole di sicurezza Firestore per Talksy
// Da deployare con: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated()
        && (
          request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid','nickname','displayName','createdAt'])
        && data.nickname is string
        && data.nickname.size() >= 3
        && data.nickname.size() <= 30;
    }

    function canModifyFriendArrays(targetUid) {
      return isAuthenticated()
        && (
          // Owner can modify their own friend-related arrays
          isOwner(targetUid)
          // A user can send a request to another user (update incomingFriendRequests of targetUid)
          || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['incomingFriendRequests'])
              && request.resource.data.incomingFriendRequests.hasAll([request.auth.uid])
              && !resource.data.incomingFriendRequests.hasAll([request.auth.uid])
          )
          // A user can accept/decline a request (update outgoingFriendRequests of targetUid)
          || (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['outgoingFriendRequests'])
              && (
                  (request.resource.data.outgoingFriendRequests.hasAll([request.auth.uid]) && !resource.data.outgoingFriendRequests.hasAll([request.auth.uid]))
                  || (!request.resource.data.outgoingFriendRequests.hasAll([request.auth.uid]) && resource.data.outgoingFriendRequests.hasAll([request.auth.uid]))
              )
          )
        );
    }

    // ── Utenti ──────────────────────────────────────
    match /users/{uid} {
      // Chiunque autenticato può leggere i profili (per ricerca amici)
      allow read: if isAuthenticated();

      // Solo il proprietario può creare/modificare il proprio profilo
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid)
        // Campi non modificabili dall\'utente
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['uid', 'isAdmin', 'createdAt', 'nickname'])
        || canModifyFriendArrays(uid);

      // Nessuno può eliminare un profilo (solo admin via SDK)
      allow delete: if false;
    }

    // ── News ─────────────────────────────────────────
    match /news/{newsId} {
      // Tutti gli autenticati possono leggere le news
      allow read: if isAuthenticated();

      // Solo gli admin possono creare news
      allow create: if isAdmin();

      // Il creatore o un admin possono modificare
      allow update: if isAdmin()
        || (isAuthenticated() && resource.data.createdBy == request.auth.uid);

      // Il creatore o un admin possono eliminare
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }

    // ── Commenti sulle news ──────────────────────────
    match /news/{newsId}/comments/{commentId} {
      // Tutti gli autenticati possono leggere i commenti
      allow read: if isAuthenticated();

      // Chiunque autenticato può commentare
      allow create: if isAuthenticated()
        && request.resource.data.authorUid == request.auth.uid;

      // Solo l\'autore del commento o un admin possono eliminarlo
      allow delete: if isAuthenticated()
        && (resource.data.authorUid == request.auth.uid || isAdmin());

      // I commenti non sono modificabili
      allow update: if false;
    }

    // ── Chat metadata ────────────────────────────────
    match /chats/{chatId} {
      // Solo i partecipanti alla chat possono leggere
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Chiunque autenticato può creare una chat (1:1 o gruppo)
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2;

      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;
    }

    // ── Notifiche push storage ──────────────────────
    match /notifications/{notifId} {
      // Solo il destinatario può leggere le sue notifiche
      allow read: if isAuthenticated() && resource.data.targetUid == request.auth.uid;

      // Scrittura controllata: i client possono creare notifiche
      // per altri utenti (es. quando inviano messaggi o richieste)
      allow create: if isAuthenticated();

      // Solo il destinatario può eliminare/marcare come lette
      allow update, delete: if isAuthenticated() && resource.data.targetUid == request.auth.uid;
    }

    // ── Annunci / Sponsor personalizzati ─────────────
    match /ads_custom/{adId} {
      // Tutti possono leggere gli annunci attivi
      allow read: if isAuthenticated();

      // Solo gli admin possono gestire gli annunci
      allow create, update, delete: if isAdmin();
    }
  }
}
