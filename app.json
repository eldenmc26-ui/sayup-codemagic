{
  "expo": {
    "name": "Talksy",
    "slug": "talksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/talksy-logo.png",
    "userInterfaceStyle": "dark",

    "splash": {
      "image": "./assets/talksy-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#075E54"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xxmauro.talksy",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Talksy usa il microfono per le chiamate vocali.",
        "NSCameraUsageDescription": "Talksy usa la fotocamera per videochiamate e foto.",
        "NSPhotoLibraryUsageDescription": "Talksy accede alla galleria per inviare immagini."
      }
    },

    "android": {
      "package": "com.xxmauro.talksy",
      "googleServicesFile": "./google-services.json"
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ]
    ]
  }
}
