{
  "expo": {
    "name": "Talksy",
    "slug": "talksy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/talksy-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/talksy-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#075E54"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xxmauro.talksy",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Talksy ha bisogno del microfono per le chiamate vocali.",
        "NSCameraUsageDescription": "Talksy ha bisogno della fotocamera per scattare foto e videochiamate.",
        "NSPhotoLibraryUsageDescription": "Talksy ha bisogno di accedere alla tua galleria per inviare immagini."
      }
    },
    "android": {
      "package": "com.xxmauro.talksy",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ]
  }
}